# Copy to .env and fill in the values for local notebook / library usage.
# These are not required when the app is deployed — the deploy pipeline
# wires the equivalent values via Databricks Asset Bundle variables.

DATABRICKS_HOST=https://<your-workspace>.cloud.databricks.com
DATABRICKS_TOKEN=<personal-access-token-or-leave-blank-to-use-cli-profile>

# Optional. Only needed if you exercise the OpenAI-direct multi-turn image
# generation path outside Databricks model serving.
OPENAI_API_KEY=
